  "keyFeatures": [
    "Sector-based scenario engine with SectorPackConfig v2",
    "HBX Workplace Readiness & Compliance with small-group suppression",
    "Capital/Public Finance and Revenue/Commercial sector packs",
    "EOS Environmental Intelligence output contracts",
    "Human-Environment Fusion object",
    "OCM-10 handoff schema",
    "Readiness Horizon projection with base/upside/downside/stress cases",
    "Projected-vs-observed comparison",
    "Executive Readiness Assessment with evidence, assumption, and confidence ledgers",
    "Observability Trace Hook",
    "Protected-Use Status Hook",
    "Safe failure responses with sanitized audit events",
    "Decision-support-only safety posture with human review required"
  ],
